# Project Info
PROJECT_NAME=Real-Time Machine Data Ingestion Service
PROJECT_DESCRIPTION=Microservice for receiving, storing, and serving real-time sensor data from industrial machines
PROJECT_VERSION=1.0.0
API_V1_STR=/api/v1

# Server Config
SERVER_HOST=localhost
SERVER_PORT=8000

# JWT Settings
SECRET_KEY=your_super_secret_auth_token
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Database Backend
DB_ENGINE=postgresql
DB_DRIVER=asyncpg
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=your_database_name
DB_PORT=5432

# InfluxDB Backend (for Sensor Data)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_super_secret_auth_token
INFLUXDB_ORG=your_org_name
INFLUXDB_BUCKET=sensor_data

# MQTT Broker (for Real-Time Sensor Ingestion)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_FILTER=factory/A/machine/+/telemetry
MQTT_CLIENT_ID=gonster-subscriber
